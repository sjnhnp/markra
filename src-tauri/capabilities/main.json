{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Permissions for the main Markra editor window.",
  "windows": [
    "main",
    "markra-*"
  ],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:menu:default",
    "core:path:default",
    "core:resources:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "dialog:allow-save",
    "store:allow-delete",
    "store:allow-get",
    "store:allow-load",
    "store:allow-save",
    "store:allow-set"
  ]
}
