{
  "name": "@markra/shared",
  "version": "0.0.1",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "default": "./src/i18n/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run --environment jsdom --globals",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@types/node": "24.10.0",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
